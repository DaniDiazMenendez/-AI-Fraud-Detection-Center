# API Configuration
VITE_API_BASE_URL=http://localhost:5000
VITE_API_TIMEOUT=30000

# Azure Services (Future Integration)
VITE_AZURE_AI_FOUNDRY_KEY=your_key_here
VITE_AZURE_AI_FOUNDRY_ENDPOINT=https://your-region.api.cognitive.microsoft.com
VITE_AZURE_OPENAI_KEY=your_key_here
VITE_AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

# Microsoft Fabric
VITE_FABRIC_WORKSPACE_ID=your_workspace_id
VITE_FABRIC_CAPACITY_ID=your_capacity_id

# Application
VITE_APP_ENV=development
VITE_APP_VERSION=1.0.0
VITE_APP_NAME=AI Fraud Detection Center

# Feature Flags
VITE_ENABLE_ANALYTICS=true
VITE_ENABLE_AI_FEATURES=true
VITE_ENABLE_REAL_TIME_UPDATES=false
